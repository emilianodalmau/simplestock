
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      // Check if user is signed in and their role in the /users collection is 'super-admin'
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
    }
    
    function isInWorkspace(workspaceId) {
      // Check if user is signed in and their workspaceId matches
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceId == workspaceId;
    }

    function hasWorkspaceRole(workspaceId, role) {
      return isInWorkspace(workspaceId) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isWorkspaceAdmin(workspaceId) {
      return hasWorkspaceRole(workspaceId, 'administrador');
    }

    // An 'orphan' admin is one who has the 'administrador' role but no workspace assigned yet.
    // This is a temporary state after sign-up and before workspace creation.
    function isOrphanAdmin() {
      let userData = getUserData(request.auth.uid);
      return isSignedIn() && userData.role == 'administrador' && userData.workspaceId == null;
    }

    // ------------------------------------------------------------------------
    // Collection: /users
    // ------------------------------------------------------------------------

    match /users/{userId} {
      // READ: 
      // - Super-admins can read any user profile.
      // - Users can read their own profile.
      // - Workspace admins can read profiles of users within their own workspace.
      allow get: if isSuperAdmin() 
                   || isOwner(userId) 
                   || (isWorkspaceAdmin(getUserData(userId).workspaceId));

      // LIST:
      // - Super-admins can list all users.
      // - Workspace admins and jefe_deposito can list users filtered by their workspaceId.
      allow list: if isSuperAdmin() 
                    || (request.query.workspaceId != null && (isWorkspaceAdmin(request.query.workspaceId) || hasWorkspaceRole(request.query.workspaceId, 'jefe_deposito')));

      // CREATE:
      // - Any authenticated user can create their OWN user document (e.g., during sign-up).
      // - Admins (super or workspace) can create users for their workspace.
      allow create: if isOwner(userId) 
                      || isSuperAdmin() 
                      || isWorkspaceAdmin(request.resource.data.workspaceId);
      
      // UPDATE:
      // - A user can update their own profile.
      // - A super-admin can update any user.
      // - A workspace admin can update users within their workspace.
      // - A new 'orphan' admin can update their OWN profile to add the workspaceId.
      allow update: if isOwner(userId)
                      || isSuperAdmin()
                      || isWorkspaceAdmin(getUserData(userId).workspaceId)
                      || (isOrphanAdmin() && isOwner(userId) && request.resource.data.keys().hasOnly(['workspaceId']));
      
      // DELETE:
      // - Only admins can delete users.
      allow delete: if isSuperAdmin() 
                      || isWorkspaceAdmin(getUserData(userId).workspaceId);
    }
    
    // ------------------------------------------------------------------------
    // Collection: /workspaces
    // ------------------------------------------------------------------------
    
    match /workspaces/{workspaceId} {
        // READ: Super-admins see all workspaces. A user can only see the workspace they belong to.
        allow get: if isSuperAdmin() || isInWorkspace(workspaceId);
        
        // LIST: Only super-admins can list all workspaces.
        allow list: if isSuperAdmin();
        
        // CREATE: 
        // - A super-admin can create any workspace.
        // - An 'administrador' without a workspace (orphan) can create ONE for themselves.
        //   This rule is critical for the initial setup flow.
        allow create: if isSuperAdmin() 
                        || (isOrphanAdmin() && request.resource.data.ownerId == request.auth.uid);

        // UPDATE: Super-admin can update any workspace. A workspace admin can update their own.
        allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        
        // DELETE: Only super-admins can delete workspaces.
        allow delete: if isSuperAdmin();
        
        // --- Subcollection Rules (CORREGIDO) ---
        
        match /{subcollectionName}/{docId} {
            allow read, write: if subcollectionName in ['clients', 'categories', 'products', 'depositos', 'suppliers', 'inventory', 'counters']
                               && (isSuperAdmin() || isInWorkspace(workspaceId));
        }
        
        // Specific rule for stock movements to allow 'jefe_deposito' to create movements.
        match /stockMovements/{movementId} {
             allow create: if isSuperAdmin() 
                            || hasWorkspaceRole(workspaceId, 'administrador') 
                            || hasWorkspaceRole(workspaceId, 'editor') 
                            || hasWorkspaceRole(workspaceId, 'jefe_deposito');
             
             // Reading/deleting movements remains restricted to admins/super-admins
             allow read, update, delete: if isSuperAdmin() || hasWorkspaceRole(workspaceId, 'administrador');
        }
    }
  }
}
