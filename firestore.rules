
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // HELPER FUNCTIONS (Versión 13 - Ajuste para creación de usuario)
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function getMyData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && getMyData().get('role', '') == 'super-admin';
    }
    
    function hasWorkspaceRole(workspaceId, role) {
      let userData = getMyData();
      return userData != null && userData.get('workspaceId', '') == workspaceId && userData.get('role', '') == role;
    }

    function isWorkspaceAdmin(workspaceId) {
      return hasWorkspaceRole(workspaceId, 'administrador');
    }

    function isInWorkspace(workspaceId) {
      let userData = getMyData();
      // Un usuario está en un workspace si su documento de usuario lo dice,
      // O si es el propietario (owner) de ese workspace.
      return isSignedIn() && (
        (userData != null && userData.get('workspaceId', '') == workspaceId) ||
        (get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid)
      );
    }

    function isOrphanAdmin() {
      let userData = getMyData();
      return isSignedIn()
             && userData.get('role', '') == 'administrador'
             && userData.get('workspaceId', null) == null;
    }


    // ------------------------------------------------------------------------
    // Collection: /users
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSuperAdmin() 
                  || isOwner(userId)
                  || (
                      isSignedIn()
                      && resource.data.workspaceId != null
                      && getMyData().workspaceId != null
                      && resource.data.workspaceId == getMyData().workspaceId
                     );

      allow list: if isSuperAdmin() 
                  || (
                      isWorkspaceAdmin(getMyData().workspaceId) &&
                      request.query.get('where', [['']])[0][0] == 'workspaceId' &&
                      request.query.get('where', [['']])[0][2] == getMyData().workspaceId
                  )
                  || ( // Rule for listing available admins
                      isSuperAdmin() &&
                      request.query.get('where', [['']])[0][0] == 'role' &&
                      request.query.get('where', [['']])[0][2] == 'administrador' &&
                      request.query.get('where', [['']])[1][0] == 'workspaceId' &&
                      request.query.get('where', [['']])[1][2] == null
                  );

      // A user can create their own profile, or an admin can create a user for their workspace.
      allow create: if (isOwner(userId)) // <-- ESTA ES LA LÍNEA CLAVE AÑADIDA
                      || isSuperAdmin() 
                      || isWorkspaceAdmin(request.resource.data.workspaceId);
      
      allow update: if isOwner(userId)
                      || isSuperAdmin()
                      || isWorkspaceAdmin(resource.data.workspaceId)
                      || (isOrphanAdmin() && isOwner(userId));

      allow delete: if isSuperAdmin() || isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ------------------------------------------------------------------------
    // Collection: /workspaces
    // ------------------------------------------------------------------------

    match /workspaces/{workspaceId} {
        allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
        allow create: if isSuperAdmin() 
                        || (isOrphanAdmin() && request.resource.data.ownerId == request.auth.uid);
        allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        allow delete: if isSuperAdmin();
    }
        
    // ------------------------------------------------------------------------
    // Subcollections
    // ------------------------------------------------------------------------
    
    match /workspaces/{workspaceId}/categories/{docId} { allow read, write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor'); }
    match /workspaces/{workspaceId}/suppliers/{docId} { allow read, write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor'); }
    match /workspaces/{workspaceId}/counters/{docId} { allow read, write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor'); }
    
    match /workspaces/{workspaceId}/products/{productId} {
        allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
        allow write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor');
    }
    
    match /workspaces/{workspaceId}/deposits/{depositId} {
        allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
        allow write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor');
    }
    
    match /workspaces/{workspaceId}/inventory/{inventoryStockId} {
        allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
        allow write: if
            (isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor'))
            ||
            (
                hasWorkspaceRole(workspaceId, 'jefe_deposito') &&
                get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(inventoryStockId.split('_')[1])).data.jefeId == request.auth.uid
            );
    }
    
    match /workspaces/{workspaceId}/stockMovements/{movementId} {
         allow read: if isSignedIn();
         
         allow create: if isSuperAdmin() || isInWorkspace(workspaceId);
         allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor');
         allow delete: if 
            isSuperAdmin() 
            || isWorkspaceAdmin(workspaceId)
            || (
                hasWorkspaceRole(workspaceId, 'jefe_deposito') &&
                get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(resource.data.depositId)).data.jefeId == request.auth.uid
               );
    }
  }
}
