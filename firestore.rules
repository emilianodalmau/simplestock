
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    // This function can ONLY be used in 'get', 'create', 'update', 'delete' rules.
    // It is UNSAFE for 'list' rules because it performs a 'get'.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // This function can be used in any rule as it only uses data from the request token.
    function isSignedIn() {
      return request.auth != null;
    }

    // USER-SPECIFIC RULES
    match /users/{userId} {
      // Users can read and update their own profile.
      allow get, update: if isSignedIn() && request.auth.uid == userId;
      
      // Allow user creation for sign-up process.
      allow create: if isSignedIn();

      // Only super-admins can list or delete users.
      allow list, delete: if isSignedIn() && getUserData().role == 'super-admin';
    }

    // WORKSPACE-LEVEL RULES
    match /workspaces/{workspaceId} {
      // Users can only read their own workspace document.
      allow read: if isSignedIn() && getUserData().workspaceId == workspaceId;
      
      // Only super-admins can list, create, update or delete workspaces directly.
      // Workspace creation by an admin is handled by Cloud Functions or transaction logic.
      allow write, list: if isSignedIn() && getUserData().role == 'super-admin';

      // --- SUBCOLLECTION RULES ---
      
      // DEFAULT RULE FOR MOST SUBCOLLECTIONS
      // - Anyone in the workspace can read.
      // - Only admins/editors can write.
      match /{collectionName in ['categories', 'products', 'suppliers', 'clients', 'deposits', 'quotes', 'inventory', 'batches']} {
        match /{docId} {
          allow read: if isSignedIn() && getUserData().workspaceId == workspaceId;
          allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor'];
        }
      }

      // OVERRIDE: Locations can also be managed by the assigned 'jefe_deposito'.
      match /deposits/{depositId} {
        match /locations/{locationId} {
          allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && (
            getUserData().role in ['administrador', 'editor'] ||
            (getUserData().role == 'jefe_deposito' && get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(depositId)).data.jefeId == request.auth.uid)
          );
        }
      }

      // OVERRIDE: Allow 'vendedor' to manage clients and quotes.
      match /{collectionName in ['clients', 'quotes']} {
        match /{docId} {
           allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor', 'vendedor'];
        }
      }
      
      // OVERRIDE: Specific rules for stockMovements
      match /stockMovements/{movementId} {
        // LIST: Crucial rule. MUST NOT contain `get`.
        // Security relies on the client querying the correct path `workspaces/{workspaceId}/...`
        allow list: if isSignedIn();

        // GET: Stricter rule for single documents is allowed.
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        
        // CREATE: More roles can create movements.
        allow create: if isSignedIn() && getUserData().workspaceId == workspaceId && 
          getUserData().role in ['administrador', 'editor', 'jefe_deposito', 'solicitante'];
          
        // UPDATE: Restricted.
        allow update: if isSignedIn() && getUserData().workspaceId == workspaceId && 
          getUserData().role in ['administrador', 'editor'];
          
        // DELETE: Restricted.
        allow delete: if isSignedIn() && getUserData().workspaceId == workspaceId && 
          (getUserData().role == 'administrador' || 
           (getUserData().role == 'jefe_deposito' && resource.data.depositId != null && 
            get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(resource.data.depositId)).data.jefeId == request.auth.uid));
      }

      // OVERRIDE: Counters can be written by any member of the workspace.
      match /counters/{counterId} {
          allow write: if isSignedIn() && getUserData().workspaceId == workspaceId;
      }
    }
    
     // COLLECTION GROUP QUERIES
     match /{path=**}/batches/{batchId} {
      allow list: if isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceId == resource.data.workspaceId;
    }
  }
}
