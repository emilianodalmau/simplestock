
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || (getUserData().role in ['administrador', 'super-admin']);
      
      // Allow user to update their own profile.
      // Allow an admin to update any user in their own workspace.
      // Allow a super-admin to update any user.
      allow update: if isOwner(userId) || 
                    (getUserData().role == 'administrador' && resource.data.workspaceId == getUserData().workspaceId) ||
                    (getUserData().role == 'super-admin');

      allow create: if isSignedIn();
      
      allow list: if isSignedIn();

      allow delete: if isSignedIn() && getUserData().role == 'super-admin';
    }

    match /workspaces/{workspaceId} {
      allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
      allow update: if isSignedIn() && (
        (getUserData().role == 'administrador' && getUserData().workspaceId == workspaceId) ||
        getUserData().role == 'super-admin'
      );
      allow list, create, delete: if isSignedIn() && getUserData().role == 'super-admin';
      
      // --- SUBCOLLECTION RULES: EXPLICIT MATCHES ---

      match /categories/{docId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor'];
      }
      
      match /products/{docId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor'];
      }

      match /deposits/{depositId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor'];
        
        match /locations/{locationId} {
            allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
            allow list: if isSignedIn();
            allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && (
              getUserData().role in ['administrador', 'editor'] ||
              (getUserData().role == 'jefe_deposito' && get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(depositId)).data.jefeId == request.auth.uid)
            );
        }
      }

      match /suppliers/{docId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor'];
      }

      match /clients/{docId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor', 'vendedor'];
      }
      
      match /quotes/{docId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor', 'vendedor'];
      }
      
      match /inventory/{docId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor', 'jefe_deposito', 'solicitante'];
      }

      match /batches/{docId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor', 'jefe_deposito'];
      }

      match /counters/{docId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor', 'jefe_deposito', 'solicitante', 'vendedor'];
      }

      match /stockMovements/{docId} {
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow list: if isSignedIn();
        allow create: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor', 'jefe_deposito', 'solicitante'];
        allow update: if isSignedIn() && getUserData().workspaceId == workspaceId && getUserData().role in ['administrador', 'editor'];
        allow delete: if isSignedIn() && getUserData().workspaceId == workspaceId && (
            getUserData().role == 'administrador' ||
            (getUserData().role == 'jefe_deposito' && resource.data.depositId != null && get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(resource.data.depositId)).data.jefeId == request.auth.uid)
        );
      }
    }
    
    // This collection group query allows listing batches across all subcollections.
    // The query is secured by the client-side code which always filters by workspaceId.
    match /{path=**}/batches/{batchId} {
     allow list: if isSignedIn();
    }
  }
}
