
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      // Super admins have their role defined in their user document.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
    }
    
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Function to check if the requesting user belongs to a specific workspace
    function isInWorkspace(workspaceId) {
        let userData = getUserData(request.auth.uid);
        return isSignedIn() && userData.workspaceId == workspaceId;
    }

    // Function to check if the user has a specific role within a workspace
    function hasWorkspaceRole(workspaceId, role) {
        let userData = getUserData(request.auth.uid);
        return isInWorkspace(workspaceId) && userData.role == role;
    }
    
    // Function to check if the user is an admin of a specific workspace
    function isWorkspaceAdmin(workspaceId) {
        return hasWorkspaceRole(workspaceId, 'administrador');
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    match /users/{userId} {
      // READ: Super-admin can read any user. Users can read their own profile.
      // An admin can read any user within their own workspace.
      allow get: if isSuperAdmin() || isOwner(userId) || (isInWorkspace(resource.data.workspaceId));
      
      // LIST: Super-admin can list all users. Workspace admins can list users in their workspace.
      allow list: if isSuperAdmin() || (request.query.limit <= 100 && isInWorkspace(request.query.workspaceId));

      // CREATE: A user can create their own user document. This is usually done at sign-up.
      // A workspace admin can also create users for their workspace.
      allow create: if isOwner(userId) || isWorkspaceAdmin(request.resource.data.workspaceId);
      
      // UPDATE: A user can update their own profile. A workspace admin or super-admin can update others.
      allow update: if isOwner(userId) || isSuperAdmin() || isWorkspaceAdmin(resource.data.workspaceId);
      
      // DELETE: Only a super-admin or workspace admin can delete users.
      allow delete: if isSuperAdmin() || isWorkspaceAdmin(resource.data.workspaceId);
    }
    
    match /workspaces/{workspaceId} {
        // READ: Super-admins can see all workspaces. Users can see their own workspace.
        allow get: if isSuperAdmin() || isInWorkspace(workspaceId);
        allow list: if isSuperAdmin();
        
        // WRITE: Only super-admins can create, update, or delete workspaces.
        // This prevents admins from creating/altering their own or other workspaces.
        allow write: if isSuperAdmin();
        
        // --- Subcollection Rules ---
        // These rules apply to all subcollections within a workspace
        match /{subcollection}/{docId} {
            // General access rule: allow read/write if the user is in the workspace or is a super-admin.
            allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId);
        }
        
         // Specific rule for stock movements to allow jefe_deposito to create
        match /stockMovements/{movementId} {
             allow create: if isSuperAdmin() || hasWorkspaceRole(workspaceId, 'administrador') || hasWorkspaceRole(workspaceId, 'editor') || hasWorkspaceRole(workspaceId, 'jefe_deposito');
             allow read, update, delete: if isSuperAdmin() || hasWorkspaceRole(workspaceId, 'administrador');
        }
    }
  }
}
