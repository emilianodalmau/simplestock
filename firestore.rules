
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // HELPER FUNCTIONS (Versión 7 - Con límites de suscripción)
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function getMyData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getWorkspace(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId));
    }
    
    function getWorkspaceData(workspaceId) {
      return getWorkspace(workspaceId).data;
    }

    function isInWorkspace(workspaceId) {
      let userData = getMyData();
      return isSignedIn() && (userData.workspaceId == workspaceId);
    }

    function hasWorkspaceRole(workspaceId, role) {
      return isInWorkspace(workspaceId) && getMyData().get('role', '') == role;
    }
    
    function isWorkspaceAdmin(workspaceId) {
      return hasWorkspaceRole(workspaceId, 'administrador');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && getMyData().get('role', '') == 'super-admin';
    }

    function isOrphanAdmin() {
      let userData = getMyData();
      return isSignedIn()
             && userData.get('role', '') == 'administrador'
             && userData.get('workspaceId', null) == null;
    }

    // --- Funciones para límites de suscripción ---

    function getCollectionSize(collectionPath) {
      return firestore.get(collectionPath).size;
    }
    
    function isWithinLimit(workspaceId, collectionName, limitKey) {
      let workspaceData = getWorkspaceData(workspaceId);
      let currentCount = getCollectionSize(/databases/$(database)/documents/workspaces/$(workspaceId)/$(collectionName));
      let limit = workspaceData.subscription.limits[limitKey];
      return currentCount < limit;
    }


    // ------------------------------------------------------------------------
    // Collection: /users
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSuperAdmin() 
                  || isOwner(userId)
                  || (
                      isSignedIn()
                      && resource.data.workspaceId != null
                      && getMyData().workspaceId != null
                      && resource.data.workspaceId == getMyData().workspaceId
                      && (getMyData().role == 'administrador' || getMyData().role == 'jefe_deposito')
                     );
      
      // La creación de usuarios ahora comprueba el límite del plan
      allow create: if isSuperAdmin() || 
                     (
                       isWorkspaceAdmin(request.resource.data.workspaceId) &&
                       isWithinLimit(request.resource.data.workspaceId, 'users', 'maxUsers')
                     );

      allow update: if isOwner(userId)
                      || isSuperAdmin()
                      || isWorkspaceAdmin(resource.data.workspaceId)
                      || (isOrphanAdmin() && isOwner(userId));

      allow delete: if isSuperAdmin() || isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ------------------------------------------------------------------------
    // Collection: /workspaces y Subcolecciones
    // ------------------------------------------------------------------------

    match /workspaces/{workspaceId} {
        allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
        
        allow create: if isSuperAdmin() 
                        || (isOrphanAdmin() && request.resource.data.ownerId == request.auth.uid);

        allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        
        allow delete: if isSuperAdmin();
        
        // --- Subcollection Rules ---
        
        match /categories/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /suppliers/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /counters/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        
        // La creación de productos ahora comprueba el límite del plan
        match /products/{productId} {
            allow read, update, delete: if isSuperAdmin() || isInWorkspace(workspaceId);
            allow create: if (isSuperAdmin() || isInWorkspace(workspaceId)) && isWithinLimit(workspaceId, 'products', 'maxProducts');
        }
        
        // La creación de depósitos ahora comprueba el límite del plan
        match /deposits/{depositId} {
            allow read, update, delete: if isSuperAdmin() || isInWorkspace(workspaceId);
            allow create: if (isSuperAdmin() || isInWorkspace(workspaceId)) && isWithinLimit(workspaceId, 'deposits', 'maxDeposits');
        }
        
        // --- INVENTORY ---
        match /inventory/{inventoryStockId} {
            allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
            allow write: if
                // Roles con acceso total de escritura
                (isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor'))
                ||
                // Regla específica para Jefe de Depósito
                (
                    hasWorkspaceRole(workspaceId, 'jefe_deposito') &&
                    // Asegura que el jefeId del depósito coincide con el UID del usuario que hace la petición
                    get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(inventoryStockId.split('_')[1])).data.jefeId == request.auth.uid
                );
        }
        
        // --- STOCK MOVEMENTS ---
        match /stockMovements/{movementId} {
             allow create: if isSuperAdmin() || isInWorkspace(workspaceId);
             allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
             allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor');
             allow delete: if 
                isSuperAdmin() 
                || isWorkspaceAdmin(workspaceId)
                || (
                    hasWorkspaceRole(workspaceId, 'jefe_deposito') &&
                    get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(resource.data.depositId)).data.jefeId == request.auth.uid
                   );
        }
    }
  }
}
