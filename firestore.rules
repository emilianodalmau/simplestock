
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // HELPER FUNCTIONS
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // WARNING: Uses get() - Not for `list` rules on standard queries.
    function getMyData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // WARNING: Uses get() - Not for `list` rules.
    function isSuperAdmin() {
      let myData = getMyData();
      return myData != null && myData.role == 'super-admin';
    }
    
    // WARNING: Uses get() - Not for `list` rules.
    function hasWorkspaceRole(workspaceId, role) {
      let myData = getMyData();
      return myData != null && myData.workspaceId == workspaceId && myData.role == role;
    }

    // WARNING: Uses get() - Not for `list` rules.
    function isWorkspaceAdmin(workspaceId) {
      return hasWorkspaceRole(workspaceId, 'administrador');
    }

    // WARNING: Uses get() - Not for `list` rules.
    function isInWorkspace(workspaceId) {
      let myData = getMyData();
      return (myData != null && myData.workspaceId == workspaceId) ||
        (get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid);
    }
    
    function isOrphanAdmin() {
      let myData = getMyData();
      return isSignedIn()
             && myData != null
             && myData.role == 'administrador'
             && myData.workspaceId == null;
    }


    // ------------------------------------------------------------------------
    // Collection: /users
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId)
                  || isSuperAdmin()
                  || (
                      // Allows a member of a workspace to get data of another member of the SAME workspace
                      getMyData() != null
                      && getMyData().workspaceId != null
                      && resource.data.workspaceId == getMyData().workspaceId
                     );

      // Client must query with `where('workspaceId', '==', ID)`.
      allow list: if isSuperAdmin() 
                   || (
                      isSignedIn() &&
                      request.query.get('where', [['']])[0][0] == 'workspaceId'
                  );

      allow create: if (isOwner(userId))
                      || isSuperAdmin() 
                      || isWorkspaceAdmin(request.resource.data.workspaceId);
      
      allow update: if isOwner(userId)
                      || isSuperAdmin()
                      || isWorkspaceAdmin(resource.data.workspaceId)
                      || (isOrphanAdmin() && isOwner(userId));

      allow delete: if isSuperAdmin() || isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ------------------------------------------------------------------------
    // Collection: /workspaces
    // ------------------------------------------------------------------------

    match /workspaces/{workspaceId} {
        allow get: if isInWorkspace(workspaceId);
        // `list` is problematic for non-super-admins and even super-admins due to get() call.
        // Assume client fetches workspaces by ID.
        allow list: if isSuperAdmin(); 
        
        allow create: if isSuperAdmin() 
                        || (isOrphanAdmin() && request.resource.data.ownerId == request.auth.uid);
        allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        allow delete: if isSuperAdmin();
    }
        
    // ------------------------------------------------------------------------
    // Subcollections
    // ------------------------------------------------------------------------
    
    match /workspaces/{workspaceId}/categories/{docId} { 
        allow get: if isInWorkspace(workspaceId);
        allow list: if isSignedIn();
        allow write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor');
    }
    match /workspaces/{workspaceId}/suppliers/{docId} { 
        allow get: if isInWorkspace(workspaceId);
        allow list: if isSignedIn();
        allow write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor');
    }
    match /workspaces/{workspaceId}/clients/{docId} { 
        allow get: if isInWorkspace(workspaceId);
        allow list: if isSignedIn();
        allow write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor') || hasWorkspaceRole(workspaceId, 'vendedor');
    }
    match /workspaces/{workspaceId}/quotes/{docId} { 
        allow get: if isInWorkspace(workspaceId);
        allow list: if isSignedIn();
        allow write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor') || hasWorkspaceRole(workspaceId, 'vendedor');
    }
    match /workspaces/{workspaceId}/products/{productId} {
        allow get: if isInWorkspace(workspaceId);
        allow list: if isSignedIn();
        allow create, update, delete: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor');
    }
    match /workspaces/{workspaceId}/inventory/{inventoryStockId} {
        allow get: if isInWorkspace(workspaceId);
        allow list: if isSignedIn();
        allow write: if
            (isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor'))
            ||
            (
                hasWorkspaceRole(workspaceId, 'jefe_deposito') &&
                get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(inventoryStockId.split('_')[1])).data.jefeId == request.auth.uid
            );
    }
    match /workspaces/{workspaceId}/counters/{docId} { 
        allow get: if isInWorkspace(workspaceId);
        allow list: if isSignedIn();
        allow write: if isInWorkspace(workspaceId); 
    }
    
    match /workspaces/{workspaceId}/deposits/{depositId} {
        allow get: if isInWorkspace(workspaceId);
        allow list: if isSignedIn();
        allow create, update, delete: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor');
        
        match /locations/{locationId} {
            allow get: if isSignedIn() && isInWorkspace(workspaceId);
            allow list: if isSignedIn();
            allow write: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor') || (hasWorkspaceRole(workspaceId, 'jefe_deposito') && get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(depositId)).data.jefeId == request.auth.uid);
        }
    }
    
    match /workspaces/{workspaceId}/batches/{batchId} { 
        allow get: if isInWorkspace(workspaceId);
        allow list: if isSignedIn();
        allow write: if isInWorkspace(workspaceId);
    }
    
    match /workspaces/{workspaceId}/stockMovements/{movementId} {
         allow get: if isInWorkspace(workspaceId);
         allow list: if isSignedIn();
         allow create: if isInWorkspace(workspaceId);
         allow update: if isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor');
         allow delete: if 
            isSuperAdmin() 
            || isWorkspaceAdmin(workspaceId)
            || (
                hasWorkspaceRole(workspaceId, 'jefe_deposito') &&
                resource.data.depositId != null &&
                get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(resource.data.depositId)).data.jefeId == request.auth.uid
               );
    }

    match /{path=**}/batches/{batchId} {
      // `get` is allowed for collection group queries.
      allow list: if isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceId == resource.data.workspaceId;
    }
  }
}
