
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Securely check for admin role from the user's own document.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'administrador';
    }

    function isEditorOrAdmin() {
      // Securely check for editor or admin role.
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isSignedIn() && (userRole in ['administrador', 'editor']);
    }
    
    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    match /users/{userId} {
      // READ: Users can get their own profile. Admins can get any profile.
      allow get, list: if isSignedIn();
      
      // CREATE: A user can only create their own user document.
      allow create: if isOwner(userId);
      
      // UPDATE: A user can update their own document. An admin can update any document (e.g., to change a role).
      allow update: if isOwner(userId) || isAdmin();
      
      // DELETE: Only admins can delete user documents for now.
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      // READ: Any signed-in user can get a single category or list all categories.
      allow get, list: if isSignedIn();
      
      // WRITE: Only editors or admins can create, update, or delete categories.
      allow write: if isEditorOrAdmin();
    }

    match /products/{productId} {
      // READ: Any signed-in user can get or list products.
      allow get, list: if isSignedIn();

      // WRITE: Only editors or admins can create, update, or delete products.
      allow write: if isEditorOrAdmin();
    }

    match /deposits/{depositId} {
      // READ: Any signed-in user can get or list deposits.
      allow get, list: if isSignedIn();

      // WRITE: Only editors or admins can create, update, or delete deposits.
      allow write: if isEditorOrAdmin();
    }
    
    match /suppliers/{supplierId} {
      // READ: Any signed-in user can get or list suppliers.
      allow get, list: if isSignedIn();

      // WRITE: Only editors or admins can create, update, or delete suppliers.
      allow write: if isEditorOrAdmin();
    }

    match /inventory/{inventoryStockId} {
      // READ: Any signed-in user can read inventory stock levels.
      allow get, list: if isSignedIn();

      // WRITE: Only editors or admins can modify stock levels.
      // This is handled via transactions in the stockMovements logic.
      allow write: if isEditorOrAdmin();
    }

    match /stockMovements/{movementId} {
      // READ: Any signed-in user can read movement history.
      allow get, list: if isSignedIn();
      // WRITE: Editors and Admins can create movements.
      allow create: if isEditorOrAdmin();
      // UPDATE: Disallowed to preserve audit trail. Annul (delete) and recreate is the pattern.
      allow update: if false;
      // DELETE: Only Admins can delete (annul) a movement to correct errors.
      allow delete: if isAdmin();
    }

    match /counters/{counterId} {
      // READ: Signed-in users can read counters (though not strictly necessary for client).
      allow get: if isSignedIn();
      // WRITE: Only authenticated users performing transactions (server-side logic is key) should update.
      // We lock this down to editors/admins for safety.
      allow write: if isEditorOrAdmin();
    }
  }
}
