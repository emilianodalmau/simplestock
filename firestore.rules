
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Securely check for admin role from the user's own document.
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'administrador';
    }

    function isEditorOrAdmin() {
      // Securely check for editor or admin role.
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (userRole == 'administrador' || userRole == 'editor');
    }
    
    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    match /users/{userId} {
      // READ: Users can get their own profile. Admins can get any profile.
      allow get: if isOwner(userId) || isAdmin();
      
      // LIST: Only admins can list all users.
      allow list: if isAdmin();
      
      // CREATE: A user can only create their own user document.
      allow create: if isOwner(userId);
      
      // UPDATE: A user can update their own document. An admin can update any document (e.g., to change a role).
      allow update: if isOwner(userId) || isAdmin();
      
      // DELETE: Only admins can delete user documents for now.
      allow delete: if isAdmin();

      match /content/{contentId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /categories/{categoryId} {
      // READ: Any signed-in user can get a single category or list all categories.
      allow get, list: if isSignedIn();
      
      // WRITE: Only editors or admins can create, update, or delete categories.
      allow write: if isEditorOrAdmin();
    }

    match /products/{productId} {
      // READ: Any signed-in user can get or list products.
      allow get, list: if isSignedIn();

      // WRITE: Only editors or admins can create, update, or delete products.
      allow write: if isEditorOrAdmin();
    }

    match /deposits/{depositId} {
      // READ: Any signed-in user can get or list deposits.
      allow get, list: if isSignedIn();

      // WRITE: Only editors or admins can create, update, or delete deposits.
      allow write: if isEditorOrAdmin();
    }
    
    match /suppliers/{supplierId} {
      // READ: Any signed-in user can get or list suppliers.
      allow get, list: if isSignedIn();

      // WRITE: Only editors or admins can create, update, or delete suppliers.
      allow write: if isEditorOrAdmin();
    }

    match /clients/{clientId} {
      // READ: Any signed-in user can get or list clients.
      allow get, list: if isSignedIn();

      // WRITE: Only editors or admins can create, update, or delete clients.
      allow write: if isEditorOrAdmin();
    }
  }
}

    