rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===========================================
    // HELPER FUNCTIONS
    // ===========================================

    // Gets the authenticated user's profile from the 'users' collection.
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Checks if the user is authenticated.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the current user's profile belongs to a specific workspace.
    function isInWorkspace(workspaceId) {
      return isAuthenticated() && getUserProfile().workspaceId == workspaceId;
    }

    // Checks if the current user has one of the specified roles within a workspace.
    function hasRole(workspaceId, roles) {
      return isInWorkspace(workspaceId) && getUserProfile().role in roles;
    }

    // Checks if the user is a super-admin.
    function isSuperAdmin() {
      return isAuthenticated() && getUserProfile().role == 'super-admin';
    }

    // ===========================================
    // COLLECTION GROUP RULES
    // ===========================================
    // This allows the 'Vencimientos' page to query batches across all inventory locations
    // within the user's workspace using collectionGroup queries.
    match /{path=**}/batches/{batchId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        getUserProfile().workspaceId == resource.data.workspaceId
      );
    }

    // ===========================================
    // USERS COLLECTION
    // ===========================================
    match /users/{userId} {
      // Users can read their own document; admins/super-admins can read all in their workspace.
      allow get: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        getUserProfile().role in ['administrador', 'editor', 'visualizador', 'jefe_deposito', 'vendedor', 'solicitante']
      );
      // Admins can list users in their workspace.
      allow list: if isAuthenticated() && (
        isSuperAdmin() ||
        getUserProfile().role == 'administrador'
      );
      // Users can update their own profile; admins can update any user in their workspace.
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        getUserProfile().role == 'administrador'
      );
      // Only admins/super-admins can create/delete users.
      allow create, delete: if isAuthenticated() && (
        isSuperAdmin() ||
        getUserProfile().role == 'administrador'
      );
    }

    // ===========================================
    // WORKSPACES COLLECTION
    // ===========================================
    match /workspaces/{workspaceId} {
      // Any authenticated user in the workspace can read workspace info.
      allow get: if isAuthenticated() && (
        isSuperAdmin() ||
        isInWorkspace(workspaceId)
      );
      allow list: if isAuthenticated() && isSuperAdmin();
      allow create: if isAuthenticated() && isSuperAdmin();
      allow update: if isAuthenticated() && (
        isSuperAdmin() ||
        hasRole(workspaceId, ['administrador'])
      );
      allow delete: if isAuthenticated() && isSuperAdmin();

      // ===========================================
      // WORKSPACE SUB-COLLECTIONS (Products, Deposits, etc.)
      // ===========================================

      // --- Products ---
      match /products/{productId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor']));
      }

      // --- Categories ---
      match /categories/{categoryId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor']));
      }

      // --- Deposits ---
      match /deposits/{depositId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor']));
      }

      // --- Suppliers ---
      match /suppliers/{supplierId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor']));
      }

      // --- Clients ---
      match /clients/{clientId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor', 'vendedor']));
      }

      // --- Inventory ---
      match /inventory/{inventoryId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor', 'jefe_deposito']));
      }

      // --- Locations ---
      match /locations/{locationId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor']));
      }

      // --- Stock Movements (Remitos / Pedidos) ---
      // This is the critical collection. Admin can see ALL movements in their workspace.
      match /stockMovements/{movementId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() ||
          hasRole(workspaceId, ['administrador', 'editor', 'visualizador', 'jefe_deposito', 'vendedor', 'solicitante'])
        );
        allow create: if isAuthenticated() && (
          isSuperAdmin() ||
          hasRole(workspaceId, ['administrador', 'editor', 'jefe_deposito', 'solicitante', 'vendedor'])
        );
        allow update: if isAuthenticated() && (
          isSuperAdmin() ||
          hasRole(workspaceId, ['administrador', 'editor', 'jefe_deposito'])
        );
        allow delete: if isAuthenticated() && (
          isSuperAdmin() ||
          hasRole(workspaceId, ['administrador'])
        );
      }

      // --- Prices ---
      match /prices/{priceId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor']));
      }

      // --- Orders / Presupuestos ---
      match /orders/{orderId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor', 'vendedor']));
      }

      // --- Batches (sub-collection of inventory) ---
      match /inventory/{inventoryId}/batches/{batchId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (isSuperAdmin() || hasRole(workspaceId, ['administrador', 'editor', 'jefe_deposito']));
      }

      // --- Counters ---
      match /counters/{counterId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          hasRole(workspaceId, ['administrador', 'editor', 'jefe_deposito', 'vendedor', 'solicitante'])
        );
      }

      // --- Metadata ---
      match /metadata/{metadataId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || isInWorkspace(workspaceId));
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          hasRole(workspaceId, ['administrador', 'editor', 'jefe_deposito', 'vendedor', 'solicitante'])
        );
      }
    }
  }
}
