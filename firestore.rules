
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'super-admin';
    }
    
    function isInWorkspace(workspaceId) {
        return isSignedIn() && getUserData(request.auth.uid).workspaceId == workspaceId;
    }

    function hasWorkspaceRole(workspaceId, role) {
        return isInWorkspace(workspaceId) && getUserData(request.auth.uid).role == role;
    }
    
    function isWorkspaceAdmin(workspaceId) {
        return hasWorkspaceRole(workspaceId, 'administrador');
    }

    // An 'orphan' admin is one who has the 'administrador' role but no workspace assigned yet.
    function isOrphanAdmin() {
      let userData = getUserData(request.auth.uid);
      return userData.role == 'administrador' && userData.workspaceId == null;
    }

    // ------------------------------------------------------------------------
    // Collection: /users
    // ------------------------------------------------------------------------

    match /users/{userId} {
      // READ: Super-admin reads any user. Workspace admin reads users in their workspace. User reads their own profile.
      allow get: if isSuperAdmin() 
                   || isOwner(userId) 
                   || (isWorkspaceAdmin(getUserData(userId).workspaceId));

      // LIST: Super-admin lists all. Workspace admin lists users in their workspace.
      allow list: if isSuperAdmin() 
                    || (request.query.workspaceId != null && isWorkspaceAdmin(request.query.workspaceId));

      // CREATE: Anyone can create their own user document (sign-up). Admins can create users for their workspace.
      allow create: if isOwner(userId) 
                      || isSuperAdmin() 
                      || isWorkspaceAdmin(request.resource.data.workspaceId);
      
      // UPDATE: A user can update their own profile (e.g., name). Admins can update users in their workspace.
      // An 'orphan' admin must be able to update their own workspaceId after workspace creation.
      allow update: if isOwner(userId) 
                      || isSuperAdmin() 
                      || isWorkspaceAdmin(getUserData(userId).workspaceId);
      
      // DELETE: Only admins can delete users.
      allow delete: if isSuperAdmin() 
                      || isWorkspaceAdmin(getUserData(userId).workspaceId);
    }
    
    // ------------------------------------------------------------------------
    // Collection: /workspaces
    // ------------------------------------------------------------------------
    
    match /workspaces/{workspaceId} {
        // READ: Super-admins see all workspaces. A user can only see the workspace they belong to.
        allow get: if isSuperAdmin() || isInWorkspace(workspaceId);
        
        // LIST: Only super-admins can list all workspaces.
        allow list: if isSuperAdmin();
        
        // CREATE: A super-admin can create any workspace.
        // An 'administrador' without a workspace (orphan) can create one (and only one) for themselves.
        allow create: if isSuperAdmin() 
                        || (isOrphanAdmin() && request.resource.data.ownerId == request.auth.uid);

        // UPDATE: Super-admin can update any workspace. A workspace admin can update their own.
        allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        
        // DELETE: Only super-admins can delete workspaces.
        allow delete: if isSuperAdmin();
        
        // --- Subcollection Rules ---
        
        // General access rule for most subcollections.
        match /{subcollection}/{docId} 
          where subcollection in ['clients', 'categories', 'products', 'deposits', 'suppliers', 'inventory', 'counters'] {
            allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId);
        }
        
        // Specific rule for stock movements to allow 'jefe_deposito' to create movements.
        match /stockMovements/{movementId} {
             allow create: if isSuperAdmin() 
                            || hasWorkspaceRole(workspaceId, 'administrador') 
                            || hasWorkspaceRole(workspaceId, 'editor') 
                            || hasWorkspaceRole(workspaceId, 'jefe_deposito');
             
             // Reading/deleting movements remains restricted to admins/super-admins
             allow read, update, delete: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        }
    }
  }
}
