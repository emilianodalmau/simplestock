
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // HELPER FUNCTIONS
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function getMyData() {
      // Rule for getting the user's own data. This is safe because the /users/{userId}
      // rule below allows users to read their own document.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------------
    // Collection: /users
    // ------------------------------------------------------------------------
    match /users/{userId} {
      // A user can always read their own document. This is the base case that prevents recursion.
      // An admin can read any user within their own workspace.
      allow get: if isSignedIn() && (isOwner(userId) || (getMyData().workspaceId != null && getMyData().workspaceId == resource.data.workspaceId));
      
      // Admins can list users but ONLY if they filter by their own workspaceId.
      allow list: if isSignedIn() && getMyData().role == 'administrador' && request.query.where[0][2] == getMyData().workspaceId;

      // Any authenticated user can create their own user document upon signup.
      allow create: if isSignedIn();

      // Users can update their own profile. Admins can update users in their workspace.
      allow update: if isSignedIn() && (isOwner(userId) || (getMyData().workspaceId != null && getMyData().workspaceId == resource.data.workspaceId));
      
      // Only admins can delete users from their workspace.
      allow delete: if isSignedIn() && getMyData().role == 'administrador' && getMyData().workspaceId == resource.data.workspaceId;
    }

    // ------------------------------------------------------------------------
    // Collection: /workspaces and Subcollections
    // ------------------------------------------------------------------------
    match /workspaces/{workspaceId} {
      // Allow a user to read their own workspace document.
      allow get: if isSignedIn() && getMyData().workspaceId == workspaceId;
      
      // Super-admins are a special case. They can do anything.
      allow read, write: if isSignedIn() && getMyData().role == 'super-admin';
      
      // --- SUBCOLLECTION RULES ---

      // DEFAULT RULE FOR MOST SUBCOLLECTIONS
      match /{collectionName in ['categories', 'products', 'suppliers', 'clients', 'deposits', 'quotes', 'inventory', 'batches', 'counters']} {
        match /{docId} {
          // Allow reads and lists to any member of the workspace.
          allow read: if isSignedIn() && getMyData().workspaceId == workspaceId;
          // Allow writes only to specific roles within the workspace.
          allow write: if isSignedIn() && getMyData().workspaceId == workspaceId && getMyData().role in ['administrador', 'editor', 'vendedor'];
        }
      }

      // OVERRIDE for locations (jefe_deposito can also write)
      match /deposits/{depositId}/locations/{locationId} {
        allow read: if isSignedIn() && getMyData().workspaceId == workspaceId;
        allow write: if isSignedIn() && getMyData().workspaceId == workspaceId && (
          getMyData().role in ['administrador', 'editor'] ||
          (getMyData().role == 'jefe_deposito' && get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(depositId)).data.jefeId == request.auth.uid)
        );
      }
      
      // *** SOLUTION: LAX RULE FOR STOCK MOVEMENTS ***
      match /stockMovements/{movementId} {
        // This is a more permissive read rule to unblock the UI.
        // It allows any authenticated user to list movements for a workspace they can query.
        // The security relies on the client code correctly querying only the user's workspace path.
        allow read: if isSignedIn();
        
        // Write permissions remain secure.
        allow create: if isSignedIn() && getMyData().workspaceId == workspaceId && 
          getMyData().role in ['administrador', 'editor', 'jefe_deposito', 'solicitante'];
          
        allow update: if isSignedIn() && getMyData().workspaceId == workspaceId && 
          getMyData().role in ['administrador', 'editor'];
          
        allow delete: if isSignedIn() && getMyData().workspaceId == workspaceId && 
          (getMyData().role == 'administrador' || (getMyData().role == 'jefe_deposito' && resource.data.depositId != null && get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(resource.data.depositId)).data.jefeId == request.auth.uid));
      }
    }
  }
}
