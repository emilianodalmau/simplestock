rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // HELPER FUNCTIONS (Optimized)
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function getMyData() {
      return getUserDoc().data;
    }

    // --- CORRECCIÓN: isWorkspaceAdmin explícito ---
    function isWorkspaceAdmin(workspaceId) {
      return hasWorkspaceRole(workspaceId, 'administrador');
    }

    // --- CORRECCIÓN: Validación más segura con .get() ---
    function isInWorkspace(workspaceId) {
       let userData = getMyData();
       return isSignedIn() 
              && userData != null 
              // Usamos .get() con valor por defecto para evitar errores si el campo falta
              && userData.get('workspaceId', '') != ''
              && (
                 userData.workspaceId == workspaceId || 
                 userData.workspaceId == /databases/$(database)/documents/workspaces/$(workspaceId)
              );
    }

    function hasWorkspaceRole(workspaceId, role) {
      let userData = getMyData();
      return isSignedIn() 
             && userData != null 
             && (
                 userData.workspaceId == workspaceId || 
                 userData.workspaceId == /databases/$(database)/documents/workspaces/$(workspaceId)
              )
             && userData.role == role;
    }

    function isSuperAdmin() {
      let userData = getMyData();
      // Uso de .get() para seguridad
      return isSignedIn() && userData != null && userData.get('role', '') == 'super-admin';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrphanAdmin() {
      let userData = getMyData();
      return isSignedIn() 
             && userData.get('role', '') == 'administrador' 
             && (userData.get('workspaceId', '') == null || userData.workspaceId == "");
    }

    // ------------------------------------------------------------------------
    // COLECCIONES
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSuperAdmin() || isOwner(userId) || isInWorkspace(resource.data.workspaceId);
      allow create: if isSuperAdmin() || isWorkspaceAdmin(request.resource.data.workspaceId);
      allow update: if isOwner(userId) || isSuperAdmin() || isWorkspaceAdmin(resource.data.workspaceId);
      allow delete: if isSuperAdmin() || isWorkspaceAdmin(resource.data.workspaceId);
    }
    
    match /workspaces/{workspaceId} {
        allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
        allow create: if isSuperAdmin() || (isOrphanAdmin() && request.resource.data.ownerId == request.auth.uid);
        allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        allow delete: if isSuperAdmin();
        
        match /categories/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /products/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /suppliers/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /inventory/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /counters/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        
        match /deposits/{docId} { 
            allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); 
        }
        
        match /orders/{orderId} {
            allow read, create: if isSuperAdmin() || isInWorkspace(workspaceId);
            allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'jefe_deposito');
        }

        // --- STOCK MOVEMENTS (CORREGIDO) ---
        match /stockMovements/{movementId} {
             // CORRECCIÓN PRINCIPAL: 
             // 1. Unificamos 'get' y 'list' en 'read'.
             // 2. Añadimos explícitamente isWorkspaceAdmin para asegurar acceso al rol.
             allow read: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || isInWorkspace(workspaceId);
             
             allow create: if isSuperAdmin() || isInWorkspace(workspaceId);
             allow update, delete: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        }
    }
  }
}
