
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }
    
    function getMyData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && getMyData().role == 'super-admin';
    }
    
    function isInWorkspace(workspaceId) {
      return isSignedIn() && getMyData().workspaceId == workspaceId;
    }

    function hasWorkspaceRole(workspaceId, role) {
      return isInWorkspace(workspaceId) && getMyData().role == role;
    }
    
    function isWorkspaceAdmin(workspaceId) {
      return hasWorkspaceRole(workspaceId, 'administrador');
    }

    function isOrphanAdmin() {
      let userData = getMyData();
      return isSignedIn() && userData.role == 'administrador' && (userData.workspaceId == null || userData.workspaceId == "");
    }

    // ------------------------------------------------------------------------
    // Collection: /users
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSuperAdmin() 
                  || isOwner(userId) 
                  || (
                      isSignedIn() 
                      && resource.data.workspaceId == getMyData().workspaceId 
                      && (getMyData().role == 'administrador' || getMyData().role == 'jefe_deposito')
                     );

      allow create: if isSuperAdmin() || (isWorkspaceAdmin(request.resource.data.workspaceId));
      
      allow update: if isOwner(userId)
                      || isSuperAdmin()
                      || isWorkspaceAdmin(resource.data.workspaceId)
                      || (isOrphanAdmin() && isOwner(userId));
      
      allow delete: if isSuperAdmin() 
                      || isWorkspaceAdmin(resource.data.workspaceId);
    }
    
    // ------------------------------------------------------------------------
    // Collection: /workspaces
    // ------------------------------------------------------------------------
    
    match /workspaces/{workspaceId} {
        allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
        
        allow create: if isSuperAdmin() 
                        || (isOrphanAdmin() && request.resource.data.ownerId == request.auth.uid);

        allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        
        allow delete: if isSuperAdmin();
        
        // --- Subcollection Rules ---
        
        match /categories/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /products/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /suppliers/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /counters/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        
        match /deposits/{depositId} {
            allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId);
        }

        // --- INVENTORY (Regla Robusta para Transacciones) ---
        match /inventory/{inventoryStockId} {
          allow read: if isSuperAdmin() 
                      || hasWorkspaceRole(workspaceId, 'administrador')
                      || hasWorkspaceRole(workspaceId, 'editor')
                      || hasWorkspaceRole(workspaceId, 'visualizador')
                      || (
                          hasWorkspaceRole(workspaceId, 'jefe_deposito') &&
                          // Permite leer si el ID del documento de inventario contiene el ID de un depósito que gestiona
                          get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(inventoryStockId.split('_')[1])).data.jefeId == request.auth.uid
                         );
          
          allow write: if isSuperAdmin() 
                       || hasWorkspaceRole(workspaceId, 'administrador')
                       || hasWorkspaceRole(workspaceId, 'editor')
                       || (
                           hasWorkspaceRole(workspaceId, 'jefe_deposito') &&
                           // Permite escribir si el ID del documento de inventario contiene el ID de un depósito que gestiona
                           // Esta regla es segura en transacciones porque no usa "resource.data"
                           get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(inventoryStockId.split('_')[1])).data.jefeId == request.auth.uid
                          );
        }
        
        // --- STOCK MOVEMENTS (Reglas Estrictas y Correctas) ---
        match /stockMovements/{movementId} {
             
             allow create: if isSuperAdmin() 
                            || isInWorkspace(workspaceId);
             
             allow get: if isSuperAdmin() 
                         || isInWorkspace(workspaceId);
            
             allow list: if 
                // GRUPO 1: Acceso TOTAL sin filtros.
                (isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor'))
                ||
                // GRUPO 2: Jefe de Depósito DEBE filtrar por `depositId`.
                (
                    hasWorkspaceRole(workspaceId, 'jefe_deposito') 
                    && request.query.keys().hasAny(['depositId']) // Asegura que el filtro 'where' exista en la query
                )
                ||
                // GRUPO 3: Solicitante DEBE filtrar por su propio `userId`.
                ( 
                  hasWorkspaceRole(workspaceId, 'solicitante') 
                  && request.query.where.userId == request.auth.uid 
                );

             allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
             
             // Permitimos que el jefe de depósito borre el pedido pendiente al procesarlo
             allow delete: if isSuperAdmin() 
                           || isWorkspaceAdmin(workspaceId)
                           || hasWorkspaceRole(workspaceId, 'jefe_deposito');
        }
    }
  }
}
