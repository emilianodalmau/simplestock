
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // HELPER FUNCTIONS
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // This function is UNSAFE for 'list' rules, but SAFE for 'get' and 'write'.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------------
    // USER PROFILES
    // ------------------------------------------------------------------------
    match /users/{userId} {
      // Users can read/update their own profile.
      allow get, update: if isOwner(userId);
      
      // Allow user creation for sign-up process.
      allow create: if isSignedIn();

      // Only super-admins can list or delete users. This is a deliberate simplification
      // to avoid get() in list rules, assuming the client for super-admin handles querying.
      allow list, delete: if isSignedIn() && getUserData().role == 'super-admin';
    }

    // ------------------------------------------------------------------------
    // WORKSPACES & SUBCOLLECTIONS
    // ------------------------------------------------------------------------
    match /workspaces/{workspaceId} {
      // Allow a user to read their own workspace document.
      allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
      
      // An admin can update their own workspace. A super-admin can update any.
      allow update: if isSignedIn() && (
        (getUserData().role == 'administrador' && getUserData().workspaceId == workspaceId) ||
        getUserData().role == 'super-admin'
      );
      
      // Super-admins can list, create, and delete any workspace.
      // The list rule here is safe because it's only for super-admins and reads from their own token data.
      allow list, create, delete: if isSignedIn() && getUserData().role == 'super-admin';
      
      // --- SUBCOLLECTION RULES ---

      // Specific rule for locations within deposits
      match /deposits/{depositId}/locations/{locationId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId;
        allow write: if isSignedIn() && getUserData().workspaceId == workspaceId && (
          getUserData().role in ['administrador', 'editor'] ||
          (getUserData().role == 'jefe_deposito' && get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(depositId)).data.jefeId == request.auth.uid)
        );
      }

      // Generic rule for all other subcollections
      // This uses a wildcard to match any other collection at this level.
      match /{collection}/{docId} {
        
        // This 'if' ensures this rule only applies to the intended collections.
        // **FIX**: Added 'stockMovements' to this list to resolve the permission error.
        allow list: if isSignedIn() &&
          collection in ['categories', 'products', 'suppliers', 'clients', 'deposits', 'quotes', 'inventory', 'batches', 'counters', 'stockMovements'];

        allow get: if isSignedIn() && getUserData().workspaceId == workspaceId &&
          collection in ['categories', 'products', 'suppliers', 'clients', 'deposits', 'quotes', 'inventory', 'batches', 'counters', 'stockMovements'];

        // Write rules for these collections
        allow create: if isSignedIn() && getUserData().workspaceId == workspaceId &&
          (
            (collection in ['categories', 'products', 'suppliers', 'deposits', 'inventory', 'batches', 'counters'] && getUserData().role in ['administrador', 'editor']) ||
            (collection in ['clients', 'quotes'] && getUserData().role in ['administrador', 'editor', 'vendedor']) ||
            (collection == 'stockMovements' && getUserData().role in ['administrador', 'editor', 'jefe_deposito', 'solicitante'])
          );
        
        allow update: if isSignedIn() && getUserData().workspaceId == workspaceId &&
          (
            (collection in ['categories', 'products', 'suppliers', 'deposits', 'inventory', 'batches', 'counters'] && getUserData().role in ['administrador', 'editor']) ||
            (collection in ['clients', 'quotes'] && getUserData().role in ['administrador', 'editor', 'vendedor']) ||
            (collection == 'stockMovements' && getUserData().role in ['administrador', 'editor'])
          );

        allow delete: if isSignedIn() && getUserData().workspaceId == workspaceId &&
          (
            (collection in ['categories', 'products', 'suppliers', 'deposits', 'clients', 'quotes', 'inventory', 'batches', 'counters'] && getUserData().role in ['administrador', 'editor']) ||
            (collection == 'stockMovements' && (
              getUserData().role == 'administrador' ||
              (getUserData().role == 'jefe_deposito' && resource.data.depositId != null && get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(resource.data.depositId)).data.jefeId == request.auth.uid)
            ))
          );
      }
    }
    
    // --- COLLECTION GROUP QUERIES ---
    // Rule for querying batches across all workspaces (if ever needed)
    match /{path=**}/batches/{batchId} {
     // This allows a client to query the 'batches' collection group, but only
     // if they filter by a workspaceId that matches their own.
     // This is a special case where get() is allowed in a list for collection group queries.
     allow list: if isSignedIn() &&
       request.query.where[0][2] == getUserData().workspaceId;
   }
  }
}
