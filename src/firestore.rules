
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // HELPER FUNCTIONS (Versión 2 Robusta)
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }
    
    // Acceso seguro al documento del usuario
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function getMyData() {
      return getUserDoc().data;
    }

    // --- FUNCIÓN CLAVE ---
    // Verifica si el workspaceId coincide, ya sea como String O como Reference (Path)
    // Esto soluciona el problema de tipos de datos mezclados
    function verifyWorkspaceMatch(userData, targetWorkspaceId) {
      return userData.workspaceId == targetWorkspaceId || 
             userData.workspaceId == /databases/$(database)/documents/workspaces/$(targetWorkspaceId);
    }

    function hasWorkspaceRole(workspaceId, role) {
      let userDoc = getUserDoc();
      return isSignedIn() 
             && userDoc != null 
             && verifyWorkspaceMatch(userDoc.data, workspaceId)
             && userDoc.data.role == role;
    }
    
    function isInWorkspace(workspaceId) {
       let userDoc = getUserDoc();
       return isSignedIn() 
              && userDoc != null 
              && verifyWorkspaceMatch(userDoc.data, workspaceId);
    }

    // Helpers derivados
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      let userDoc = getUserDoc();
      return isSignedIn() && userDoc != null && userDoc.data.role == 'super-admin';
    }
    
    function isWorkspaceAdmin(workspaceId) {
      return hasWorkspaceRole(workspaceId, 'administrador');
    }

    function isOrphanAdmin() {
      let userData = getMyData();
      return isSignedIn() && userData.role == 'administrador' && (userData.workspaceId == null || userData.workspaceId == "");
    }

    // ------------------------------------------------------------------------
    // COLECCIONES PRINCIPALES
    // ------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isSuperAdmin() 
                  || isOwner(userId) 
                  || (
                      isInWorkspace(resource.data.workspaceId)
                      && (getMyData().role == 'administrador' || getMyData().role == 'jefe_deposito')
                     );

      allow create: if isSuperAdmin() || isWorkspaceAdmin(request.resource.data.workspaceId);
      
      allow update: if isOwner(userId)
                      || isSuperAdmin()
                      || isWorkspaceAdmin(resource.data.workspaceId)
                      || (isOrphanAdmin() && isOwner(userId));
      
      allow delete: if isSuperAdmin() 
                      || isWorkspaceAdmin(resource.data.workspaceId);
    }
    
    // ------------------------------------------------------------------------
    // WORKSPACES Y SUBCOLECCIONES
    // ------------------------------------------------------------------------
    
    match /workspaces/{workspaceId} {
        allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
        
        allow create: if isSuperAdmin() 
                        || (isOrphanAdmin() && request.resource.data.ownerId == request.auth.uid);

        allow update: if isSuperAdmin() || isWorkspaceAdmin(workspaceId);
        
        allow delete: if isSuperAdmin();
        
        // --- Subcolecciones Simples ---
        match /categories/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /products/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /suppliers/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /counters/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        match /deposits/{docId} { allow read, write: if isSuperAdmin() || isInWorkspace(workspaceId); }
        
        // --- INVENTORY (CORRECCIÓN QUIRÚRGICA) ---
        match /inventory/{inventoryStockId} {
          allow read: if isSuperAdmin() || isInWorkspace(workspaceId);
          allow write: if 
            // Roles con acceso total
            (isSuperAdmin() || isWorkspaceAdmin(workspaceId) || hasWorkspaceRole(workspaceId, 'editor'))
            || 
            // Regla específica y segura para Jefe de Depósito
            (
              hasWorkspaceRole(workspaceId, 'jefe_deposito') &&
              // Se extrae el depositId del ID del documento de inventario ('productId_depositId')
              // y se verifica que el usuario es el jefe de ese depósito.
              // Esta regla es segura para transacciones porque no usa 'resource.data'
              get(/databases/$(database)/documents/workspaces/$(workspaceId)/deposits/$(inventoryStockId.split('_')[1])).data.jefeId == request.auth.uid
            );
        }

        // --- PEDIDOS (ORDERS - NO USADO ACTUALMENTE, SE PUEDE ELIMINAR) ---
        match /orders/{orderId} {
            allow read: if isSuperAdmin() 
                        || hasWorkspaceRole(workspaceId, 'administrador')
                        || hasWorkspaceRole(workspaceId, 'editor')
                        || hasWorkspaceRole(workspaceId, 'jefe_deposito')
                        || (isInWorkspace(workspaceId) && resource.data.userId == request.auth.uid);

            allow create: if isSuperAdmin() || isInWorkspace(workspaceId);

            allow update: if isSuperAdmin() 
                          || hasWorkspaceRole(workspaceId, 'administrador')
                          || hasWorkspaceRole(workspaceId, 'jefe_deposito');
        }

        // --- STOCK MOVEMENTS (REGLAS FUNCIONALES ACTUALES) ---
        match /stockMovements/{movementId} {
             
             // CREATE
             allow create: if isSuperAdmin() 
                            || isInWorkspace(workspaceId); 
             
             // GET (Detalle)
             allow get: if isSuperAdmin() 
                          || hasWorkspaceRole(workspaceId, 'administrador')
                          || hasWorkspaceRole(workspaceId, 'editor')
                          || hasWorkspaceRole(workspaceId, 'jefe_deposito')
                          || (resource.data.userId == request.auth.uid);
            
             // LIST (Lista general)
             allow list: if 
               (
                 isSuperAdmin() || 
                 isWorkspaceAdmin(workspaceId) || 
                 hasWorkspaceRole(workspaceId, 'editor') || 
                 hasWorkspaceRole(workspaceId, 'jefe_deposito') ||
                 hasWorkspaceRole(workspaceId, 'solicitante')
               );

             // UPDATE/DELETE
             allow update, delete: if isSuperAdmin() || isWorkspaceAdmin(workspaceId) || (hasWorkspaceRole(workspaceId, 'jefe_deposito') && request.resource.data.type == 'salida');
        }
    }
  }
}
